generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CartStatus {
  NOT_RECOVERED
  RECOVERED
  EXPIRED
}

model Session {
  id                  String    @id @db.VarChar(255)
  shop                String    @db.VarChar(255)
  state               String    @db.VarChar(255)
  isOnline            Boolean   @default(false)
  scope               String?   @db.VarChar(255)
  expires             DateTime?
  accessToken         String    @db.Text
  userId              BigInt?
  firstName           String?   @db.VarChar(255)
  lastName            String?   @db.VarChar(255)
  email               String?   @db.VarChar(255)
  accountOwner        Boolean   @default(false)
  locale              String?   @db.VarChar(255)
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?   @db.Text
  refreshTokenExpires DateTime?
}

model SavedCart {
  id               Int         @id @default(autoincrement())
  shop             String      @db.VarChar(255)
  token            String      @unique @db.VarChar(255)

  status           CartStatus  @default(NOT_RECOVERED)

  customerName     String?     @db.VarChar(255)
  customerEmail    String?     @db.VarChar(255)

  region           String?     @db.VarChar(255)

  // Stored in smallest currency unit (e.g. cents/paise)
  subtotal         Int         @default(0)
  total            Int         @default(0)

  cartJson         Json

  recoveredOrderId String?     @db.VarChar(255)

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  items            SavedCartItem[]

  @@index([shop, createdAt])
  @@index([shop, status])
  @@index([customerEmail])
}

model SavedCartItem {
  id             Int       @id @default(autoincrement())
  savedCartId    Int

  productId      String?   @db.VarChar(255)
  variantId      String    @db.VarChar(255)

  title          String    @db.VarChar(255)
  variantTitle   String?   @db.VarChar(255)

  sku            String?   @db.VarChar(255)

  quantity       Int
  price          Int

  propertiesJson Json?

  imageUrl       String?   @db.Text

  savedCart      SavedCart @relation(fields: [savedCartId], references: [id], onDelete: Cascade)

  @@index([savedCartId])
  @@index([variantId])
}

model MerchantStorefrontSession {
  id        Int      @id @default(autoincrement())

  shop      String   @db.VarChar(255)
  token     String   @unique @db.VarChar(255)

  email     String?  @db.VarChar(255)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([shop, expiresAt])
}
